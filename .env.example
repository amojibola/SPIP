# ─── DATABASE ────────────────────────────────────────────────────────────────
POSTGRES_DB=spip_db
POSTGRES_USER=spip_user
POSTGRES_PASSWORD=sp_user1234
DATABASE_URL=postgresql+asyncpg://spip_user:sp_user1234@db:5432/spip_db

# ─── SECURITY ────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CHANGE_THIS_GENERATE_WITH_COMMAND_ABOVE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ─── AI ──────────────────────────────────────────────────────────────────────
# Configure at least one AI provider
OPENAI_API_KEY=sk-proj-CHANGE_THIS
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-CHANGE_THIS
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
AI_MAX_TOKENS=2048
EMBEDDING_DIMENSIONS=1536
RAG_TOP_K=5

# ─── EMAIL (Mailgun or SendGrid recommended) ──────────────────────────────────
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASSWORD=CHANGE_THIS
EMAIL_FROM=SPIP Platform <noreply@yourdomain.com>
EMAIL_VERIFY_EXPIRE_HOURS=24
PASSWORD_RESET_EXPIRE_HOURS=1

# ─── APP ─────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_URL=https://yourdomain.com
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
PROFICIENCY_THRESHOLD=0.70
SMALL_GROUP_SUPPRESSION_THRESHOLD=5
MAX_CSV_UPLOAD_ROWS=5000
MAX_CSV_FILE_SIZE_MB=10

# ─── NGINX ───────────────────────────────────────────────────────────────────
# false (default): auto-detect SSL certs; true: require certs and fail if missing
NGINX_FORCE_HTTPS=false

# ─── NEXT.JS ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_SECRET=CHANGE_THIS_TO_RANDOM_32_CHAR_STRING
